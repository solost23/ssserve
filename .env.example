# Public host used in subscription URLs and VLESS/Clash server fields.
# Use your node domain here, not the raw server IP, if clients should connect by domain.
SERVER_ADDR=202.182.111.110.sslip.io
NODE_NAME=Tokyo
ADMIN_SECRET=replace-with-a-long-random-secret
NGINX_CONF=nginx.conf

# Public VLESS REALITY port.
# Use 443 for VLESS-only deployments. If Trojan+TLS uses 443, move VLESS to 8443.
XRAY_PORT=8443
XRAY_API_ADDR=xray:10085
XRAY_INBOUND_TAG=vless-in

# Generate with:
# docker run --rm ghcr.io/xtls/xray-core x25519
XRAY_PRIVATE_KEY=replace-with-reality-private-key
XRAY_PUBLIC_KEY=replace-with-reality-public-key

# 8-16 hex chars. Example:
# openssl rand -hex 8
XRAY_SHORT_ID=replacehex

# A real TLS site used by REALITY. Keep SERVER_NAME aligned with DEST host.
XRAY_SERVER_NAME=www.cloudflare.com
XRAY_DEST=www.cloudflare.com:443

# Optional Shadowrocket-compatible Trojan + TLS inbound.
# Requires a certificate under certbot/conf/live/${TROJAN_DOMAIN}/.
# When enabled, keep TROJAN_PORT=443 and XRAY_PORT on a different port such as 8443.
TROJAN_ENABLED=false
TROJAN_DOMAIN=202.182.111.110.sslip.io
TROJAN_PORT=443
TROJAN_INBOUND_TAG=trojan-in
